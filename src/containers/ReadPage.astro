---
import Article from "../components/Article/Article.astro";
import NavBar from "../components/NavBar/NavBar.astro";

interface Props {
    articleId: number;
    title: string;
    content: string;
}

const { articleId, title, content } = Astro.props;
---

<NavBar title={title} articleId={articleId} />
<Article content={content} />
