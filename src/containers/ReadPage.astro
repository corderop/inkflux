---
import Article from "../components/Article/Article.astro";
import NavBar from "../components/NavBar/NavBar.astro";

interface Props {
  articleNumber: number;
  entryId: number;
  title: string;
  feedTitle: string;
  isFirstArticle: boolean;
  isLastArticle: boolean;
  isArticleUnread: boolean;
  content: string;
}

const {
  articleNumber,
  entryId,
  title,
  feedTitle,
  isFirstArticle,
  isLastArticle,
  content,
  isArticleUnread,
} = Astro.props;
---

<NavBar
  entryId={entryId}
  title={title}
  feedTitle={feedTitle}
  previousArticleUrl={!isFirstArticle ? `/articles/${articleNumber - 1}` : null}
  nextArticleUrl={!isLastArticle ? `/articles/${articleNumber + 1}` : null}
  isUnread={isArticleUnread}
/>
<Article content={content} />
