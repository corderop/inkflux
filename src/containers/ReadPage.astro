---
import Article from "../components/Article/Article.astro";
import NavBar from "../components/NavBar/NavBar.astro";

interface Props {
    articleId: number;
    title: string;
    content: string;
    feedTitle: string;
}

const { articleId, title, content, feedTitle } = Astro.props;
---

<NavBar
    title={title}
    feedTitle={feedTitle}
    previousArticleUrl={articleId > 0 ? `/articles/${articleId - 1}` : null}
    nextArticleUrl={`/articles/${articleId + 1}`}
/>
<Article content={content} />
