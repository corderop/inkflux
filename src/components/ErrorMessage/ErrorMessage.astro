---
import WarningIcon from "../icons/Warning.astro";

interface Props {
  id?: string;
  message?: string;
}

const { id, message = "Your login credentials are invalid" } = Astro.props;
---

<div class="error-message" id={id} role="alert">
  <div class="main-message">
    <span>
      <WarningIcon />
    </span>
    <p>{message}</p>
  </div>
  <ul>
    <li>
      Ensure the API URL is in the correct format (e.g.,
      <b>https://your-instance.tld</b>).
    </li>
    <li>Verify that your API token is valid.</li>
  </ul>
</div>

<style>
  .error-message {
    display: flex;
    align-items: center;
    color: red;
    padding: 1rem;
    border-radius: 0.375rem;
    border: 1px solid red;
    margin-top: 1rem;
    flex-direction: column;
  }

  .main-message {
    display: flex;
    align-items: center;
  }

  .main-message p {
    display: inline;
    margin: 0;
    font-weight: bold;
  }

  .main-message span {
    display: inline-block;
    width: 20px;
    height: 20px;
    margin-right: 0.25rem;
  }

  .error-message ul {
    list-style: disc;
    padding-left: 2rem;
    margin-top: 1rem;
    margin-bottom: 0;
    text-align: left;
  }

  .error-message li {
    margin-bottom: 0.25rem;
  }
</style>
