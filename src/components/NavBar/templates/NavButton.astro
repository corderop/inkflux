---
interface Props {
  isHidden?: boolean;
}

const { isHidden = false } = Astro.props;
---

<li class="nav-button" style={isHidden ? "visibility: hidden" : ""}>
  <slot />
</li>

<style>
  .nav-button {
    flex-grow: 0;
    flex-shrink: 0;
    height: 20px;
    width: 20px;
    margin: 0 0.2rem;
  }
</style>
