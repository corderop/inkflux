---
import LogoutModal from "./actions/LogoutModal.astro";
import NavButton from "./templates/NavButton.astro";
import NavTitle from "./templates/NavTitle.astro";
import IconLink from "./templates/IconLink.astro";
import ArrowLeft from "../icons/ArrowLeft.astro";
import FunnelIcon from "../icons/FunnelIcon.astro";
import LogoutIcon from "../icons/LogoutIcon.astro";
import EyeIcon from "../icons/EyeIcon.astro";
import EyeSlashIcon from "../icons/EyeSlashIcon.astro";

interface Props {
  title: string;
  backUrl?: string;
  showFilter?: boolean;
  entryId?: number;
  entryStatus?: "read" | "unread";
}

const { title, backUrl, showFilter, entryId, entryStatus } = Astro.props;
---

<nav>
  <ul>
    {
      showFilter && (
        <NavButton>
          <button id="filterBtn" class="icon-btn" aria-label="Filter feeds">
            <FunnelIcon />
          </button>
        </NavButton>
      )
    }

    {
      backUrl && (
        <NavButton>
          <IconLink url={backUrl!}>
            <ArrowLeft />
          </IconLink>
        </NavButton>
      )
    }

    <NavTitle title={title} />

    {
      entryId && entryStatus && (
        <NavButton>
          <button
            id="toggleReadBtn"
            class="icon-btn"
            data-entry-id={entryId}
            data-entry-status={entryStatus}
            aria-label={
              entryStatus === "read" ? "Mark as unread" : "Mark as read"
            }
          >
            <span
              class="icon-read"
              style={entryStatus === "read" ? "" : "display: none;"}
            >
              <EyeSlashIcon />
            </span>
            <span
              class="icon-unread"
              style={entryStatus === "read" ? "display: none;" : ""}
            >
              <EyeIcon />
            </span>
          </button>
        </NavButton>
      )
    }

    <NavButton>
      <button id="logoutBtn" class="icon-btn" aria-label="Log out">
        <LogoutIcon />
      </button>
    </NavButton>
  </ul>
</nav>

<LogoutModal url="/api/logout" />

<style>
  nav {
    border-bottom: 1px solid #ddd;
    margin: 0;
    padding: 0;
    /* Make the Nav to always stay at top */
    position: sticky;
    top: 0;
    background-color: #fff;
  }
  ul {
    list-style-type: none;
    padding: 0.5rem;
    margin: 0;
    display: flex;
  }
  .icon-btn {
    background: none;
    color: #000;
    border: none;
    padding: 0;
    cursor: pointer;
    font: inherit;
    outline: inherit;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import { API_EVENTS } from "../../lib/client/events";

  const filterBtn = document.getElementById("filterBtn");
  if (filterBtn) {
    filterBtn.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent("inkflux:open-filter"));
    });
  }

  const logoutBtn = document.getElementById("logoutBtn");
  if (logoutBtn) {
    logoutBtn.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent("inkflux:open-logout"));
    });
  }

  const toggleReadBtn = document.getElementById("toggleReadBtn");
  if (toggleReadBtn) {
    toggleReadBtn.addEventListener("click", function () {
      const entryId = this.getAttribute("data-entry-id");
      const currentStatus = this.getAttribute("data-entry-status");
      const nextStatus = currentStatus === "read" ? "unread" : "read";

      this.setAttribute("data-entry-status", nextStatus);
      this.setAttribute(
        "aria-label",
        nextStatus === "read" ? "Mark as unread" : "Mark as read",
      );

      const iconRead = this.querySelector(".icon-read") as HTMLElement;
      const iconUnread = this.querySelector(".icon-unread") as HTMLElement;

      if (iconRead && iconUnread) {
        if (nextStatus === "read") {
          iconRead.style.display = "";
          iconUnread.style.display = "none";
        } else {
          iconRead.style.display = "none";
          iconUnread.style.display = "";
        }
      }

      document.dispatchEvent(
        new CustomEvent(API_EVENTS.TOGGLE_READ, {
          detail: {
            entryId,
            status: nextStatus,
          },
        }),
      );
    });

    document.addEventListener(
      API_EVENTS.TOGGLE_READ_ERROR,
      function (e: Event) {
        const customEvent = e as CustomEvent;
        const detail = customEvent.detail;
        if (!detail) return;

        if (toggleReadBtn.getAttribute("data-entry-id") == detail.entryId) {
          const revertedStatus = detail.status === "read" ? "unread" : "read";
          toggleReadBtn.setAttribute("data-entry-status", revertedStatus);
          toggleReadBtn.setAttribute(
            "aria-label",
            revertedStatus === "read" ? "Mark as unread" : "Mark as read",
          );

          const iconRead = toggleReadBtn.querySelector(
            ".icon-read",
          ) as HTMLElement;
          const iconUnread = toggleReadBtn.querySelector(
            ".icon-unread",
          ) as HTMLElement;

          if (iconRead && iconUnread) {
            if (revertedStatus === "read") {
              iconRead.style.display = "";
              iconUnread.style.display = "none";
            } else {
              iconRead.style.display = "none";
              iconUnread.style.display = "";
            }
          }
        }
      },
    );
  }
</script>
