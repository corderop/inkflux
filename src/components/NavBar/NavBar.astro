---
import LogoutModal from "./actions/LogoutModal.astro";
import NavButton from "./templates/NavButton.astro";
import NavTitle from "./templates/NavTitle.astro";
import IconLink from "./templates/IconLink.astro";
import ArrowLeft from "../icons/ArrowLeft.astro";
import FunnelIcon from "../icons/FunnelIcon.astro";
import LogoutIcon from "../icons/LogoutIcon.astro";

interface Props {
  title: string;
  backUrl?: string;
  showFilter?: boolean;
}

const { title, backUrl, showFilter } = Astro.props;
---

<nav>
  <ul>
    {
      showFilter && (
        <NavButton>
          <button id="filterBtn" class="icon-btn" aria-label="Filter feeds">
            <FunnelIcon />
          </button>
        </NavButton>
      )
    }

    {
      backUrl && (
        <NavButton>
          <IconLink url={backUrl!}>
            <ArrowLeft />
          </IconLink>
        </NavButton>
      )
    }

    <NavTitle title={title} />

    <NavButton>
      <button id="logoutBtn" class="icon-btn" aria-label="Log out">
        <LogoutIcon />
      </button>
    </NavButton>
  </ul>
</nav>

<LogoutModal url="/api/logout" />

<style>
  nav {
    border-bottom: 1px solid #ddd;
    margin: 0;
    padding: 0;
    /* Make the Nav to always stay at top */
    position: sticky;
    top: 0;
    background-color: #fff;
  }
  ul {
    list-style-type: none;
    padding: 0.5rem;
    margin: 0;
    display: flex;
  }
  .icon-btn {
    background: none;
    color: #000;
    border: none;
    padding: 0;
    cursor: pointer;
    font: inherit;
    outline: inherit;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  const filterBtn = document.getElementById("filterBtn");
  if (filterBtn) {
    filterBtn.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent("inkflux:open-filter"));
    });
  }

  const logoutBtn = document.getElementById("logoutBtn");
  if (logoutBtn) {
    logoutBtn.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent("inkflux:open-logout"));
    });
  }
</script>
