---
import Logout from "./actions/Logout.astro";
import NavButton from "./templates/NavButton.astro";
import NavTitle from "./templates/NavTitle.astro";
import IconLink from "./templates/IconLink.astro";
import ArrowLeft from "../icons/ArrowLeft.astro";

interface Props {
  title: string;
  backUrl?: string;
}

const { title, backUrl } = Astro.props;
---

<nav>
  <ul>
    {
      backUrl && (
        <NavButton>
          <IconLink url={backUrl}>
            <ArrowLeft />
          </IconLink>
        </NavButton>
      )
    }

    <NavTitle title={title} />

    <NavButton>
      <Logout url="/api/logout" />
    </NavButton>
  </ul>
</nav>

<style>
  nav {
    border-bottom: 1px solid #ddd;
    margin: 0;
    padding: 0;
    /* Make the Nav to always stay at top */
    position: sticky;
    top: 0;
    background-color: #fff;
  }
  ul {
    list-style-type: none;
    padding: 0.5rem;
    margin: 0;
    display: flex;
  }
</style>
