---
import BackwardIcon from "../icons/BackwardIcon.astro";
import ForwardIcon from "../icons/ForwardIcon.astro";

/**
 * @typedef {object} Props
 * @property {string} title - The title of the current article.
 * @property {string} feedTitle - The title of the feed the article belongs to.
 * @property {string | null} previousArticleUrl - The URL of the previous article, or null if there isn't one.
 * @property {string | null} nextArticleUrl - The URL of the next article, or null if there isn't one.
 */
interface Props {
    title: string;
    feedTitle: string;
    previousArticleUrl: string | null;
    nextArticleUrl: string | null;
}

/**
 * NavBar component displays a navigation bar with the current article's title,
 * its feed's title, and navigation buttons for the previous and next articles.
 * The navigation buttons are disabled if there is no previous or next article.
 */
const { title, feedTitle, previousArticleUrl, nextArticleUrl } = Astro.props;
---

<nav>
    <ul>
        <li class="nav-button">
            <a
                href={previousArticleUrl}
                class={Boolean(previousArticleUrl) ? "" : "disabled"}
            >
                <BackwardIcon />
            </a>
        </li>
        <li class="nav-title">
            <h1>{feedTitle} - {title}</h1>
        </li>
        <li class="nav-button">
            <a
                href={nextArticleUrl}
                class={Boolean(nextArticleUrl) ? "" : "disabled"}
            >
                <ForwardIcon />
            </a>
        </li>
    </ul>
</nav>

<style>
    nav {
        border-bottom: 1px solid #ddd;
        margin: 0;
        padding: 0;
        /* Make the Nav to always stay at top */
        position: sticky;
        top: 0;
        background-color: #fff;
    }
    ul {
        list-style-type: none;
        padding: 0.5rem;
        margin: 0;
        display: flex;
    }
    .nav-title {
        flex-grow: 1;
        flex-shrink: 1;
        margin: 0 1rem;
        overflow: hidden;
    }
    .nav-title h1 {
        margin: 0;
        /* Text styles */
        font-size: 0.85rem;
        text-align: center;
        font-weight: bold;
        line-height: 20px;
        /* Overflow title will be hidden behind ... */
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }
    .nav-button {
        flex-grow: 0;
        flex-shrink: 0;
        height: 20px;
        width: 20px;
    }
    .nav-button a {
        color: #000;
        text-decoration: none;
    }

    .nav-button a.disabled {
        color: #fff;
    }
</style>
