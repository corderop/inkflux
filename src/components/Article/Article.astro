---
import DOMPurify from "isomorphic-dompurify";

interface Props {
    content: string;
}

const { content } = Astro.props;
const sanitizedContent = DOMPurify.sanitize(content);
---

<article class="ink-article" set:html={sanitizedContent} />

<style>
    article {
        padding: 1rem;
        line-height: 1.6;
        font-size: 1rem;
        color: #000;
    }

    article :global(figure) {
        margin: 0;
        max-width: 100%;
    }

    article :global(figcaption) {
        text-align: center;
        text-wrap: balance;
    }

    article :global(img) {
        max-width: 100%;
        height: auto;
        display: block;
        margin: 1rem auto;
    }
</style>
