---
import DOMPurify from "isomorphic-dompurify";

interface Props {
    content: string;
}

const { content } = Astro.props;
const sanitizedContent = DOMPurify.sanitize(content);
---

<article set:html={sanitizedContent} />

<style>
    article {
        padding: 1rem;
        line-height: 1.6;
        font-size: 1rem;
        color: #000;
    }
    article p {
        margin-bottom: 1rem;
    }
</style>
