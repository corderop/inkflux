---
import type { Entry } from "../../lib/miniflux-client/types";

interface Props {
  entry: Entry;
}

const { entry } = Astro.props;
---

<li class="unread-item">
  <a href={`/read/${entry.id}`} class="entry-link">
    <div class="feed-info">
      <span class="feed-title">{entry.author || entry.feed.title}</span>
      <span class="category">{entry.feed.category.title}</span>
      <span class="reading-time">{entry.reading_time} min</span>
    </div>
    <h3 class="entry-title">{entry.title}</h3>
  </a>
</li>

<style>
  .unread-item {
    border-bottom: 1px solid #ddd;
    list-style: none;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .entry-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
    height: 100%;
    flex: 1;
    padding: 1.5rem 1rem;
    box-sizing: border-box;
  }

  .feed-info {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    gap: 0.5rem;
    align-items: center;
    font-size: 1rem;
    color: #666;
    margin-bottom: 0.5rem;
    font-weight: bold;
  }

  .feed-title {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    text-align: left;
  }

  .category {
    white-space: nowrap;
    text-align: center;
  }

  .reading-time {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    text-align: right;
  }

  .entry-title {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.3;
    font-weight: 500;
    color: #222;
  }
</style>
