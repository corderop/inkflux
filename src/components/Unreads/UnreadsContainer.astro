---
import UnreadsList from "./UnreadsList.astro";
import { MinifluxClient } from "../../lib/miniflux-client";
import { FilteredEntriesRepository } from "../../lib/filtered-entries-repository";
import { getFilterStateFromCookies } from "../../lib/feed-filter-store/server";
import {
  ARTICLE_LIMIT,
  FILTER_BATCH_SIZE,
  FILTER_MAX_API_CALLS,
} from "../../config";

import {
  MinifluxAuthError,
  MinifluxBadRequestError,
  MinifluxNotFoundError,
} from "../../lib/miniflux-client/errors";

interface Props {
  url: string;
  apiToken: string;
}

const { url, apiToken } = Astro.props;

const minifluxClient = new MinifluxClient(url, apiToken);
const repository = new FilteredEntriesRepository(minifluxClient);
const filterState = getFilterStateFromCookies(Astro.cookies);

let feeds;
let entries;
try {
  [feeds, entries] = await Promise.all([
    minifluxClient.getFeeds(),
    repository.getFilteredUnreadEntries({
      filterState,
      limit: ARTICLE_LIMIT,
      batchSize: FILTER_BATCH_SIZE,
      maxCalls: FILTER_MAX_API_CALLS,
    }),
  ]);
} catch (error) {
  if (error instanceof MinifluxAuthError) {
    return Astro.rewrite("/api/logout");
  } else if (error instanceof MinifluxBadRequestError) {
    return Astro.rewrite("/400");
  } else if (error instanceof MinifluxNotFoundError) {
    return Astro.rewrite("/404");
  } else {
    return Astro.rewrite("/500");
  }
}
---

<UnreadsList
  entries={entries}
  feeds={feeds}
  excludedCategoryIds={filterState.excludedCategoryIds}
  excludedFeedIds={filterState.excludedFeedIds}
/>
