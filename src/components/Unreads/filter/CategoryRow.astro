---
interface Props {
  categoryId: number;
  title: string;
  isIncluded: boolean;
}

const { categoryId, title, isIncluded } = Astro.props;
---

<label class="category-row">
  <input
    type="checkbox"
    class="filter-category-cb"
    value={categoryId}
    data-category-id={categoryId}
    checked={isIncluded}
  />
  <span class="category-name">{title}</span>
  <span class="expand-indicator" aria-hidden="true">
    {isIncluded ? "▼" : "▶"}
  </span>
</label>

<style>
  .category-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    font-size: 1rem;
    font-weight: bold;
    background: #f5f5f5;
    cursor: pointer;
  }

  .category-row input[type="checkbox"] {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    cursor: pointer;
  }

  .category-name {
    flex: 1;
  }

  .expand-indicator {
    font-size: 0.75rem;
    color: #555;
    flex-shrink: 0;
  }
</style>
